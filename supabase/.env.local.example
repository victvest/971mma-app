# Local-only Supabase CLI secrets — never commit (gitignored).
#
# Used by:
#   node scripts/invoke-edge.mjs mb-link
#   node scripts/configure-auth-smtp.mjs

# Required for `supabase db push` / remote DB access
SUPABASE_DB_PASSWORD=

# Optional: Phase 12 runtime RLS tests via supabase db query + TEST_USER (no service role required)
# SUPABASE_SERVICE_ROLE_KEY=
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Optional: direct Mindbody parity script (copy values from Supabase Edge secrets)
# MINDBODY_BASE_URL=https://api.mindbodyonline.com/public/v6
# MINDBODY_API_KEY=
# MINDBODY_SITE_ID=-99
# MINDBODY_SOURCE_NAME=
# MINDBODY_SOURCE_PASSWORD=

# Optional: dev-only gate scan geofence override (see gate entry docs)
# EXPO_PUBLIC_DEV_GATE_LAT=25.1234
# EXPO_PUBLIC_DEV_GATE_LNG=55.1234
# ACADEMY_LAT=25.1309
# ACADEMY_LNG=55.2320
# GATE_LOCATION_ID=971mma-al-quoz

# Optional: custom SMTP for reliable signup confirmation emails.
# Without these, Supabase's built-in mailer caps at ~2 emails/hour and often lands in spam.
# Resend example: host=smtp.resend.com, port=465, user=resend, pass=re_xxx
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=971 MMA

# 971 MMA — environment config
# Copy to `.env` and fill in. NEVER commit `.env` (gitignored).
#
# SECURITY:
#  - EXPO_PUBLIC_* vars are bundled into the client. Only put publishable keys here.
#  - Use only the Supabase ANON key (not service_role) — RLS is the real protection.
#  - Get keys from: Supabase Dashboard → Project Settings → API

# --- Supabase (required) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Integration provider switch (optional) ---
# Only `supabase` is supported. Direct Mindbody client access is disabled.
EXPO_PUBLIC_MEMBER_PROVIDER=supabase
EXPO_PUBLIC_CHECKIN_PROVIDER=supabase

# --- Coach fixtures (optional, dev/staging only) ---
# Injects local coach schedule/promotions when live sync is empty. Must stay false in production.
EXPO_PUBLIC_COACH_DEMO_MODE=false

# --- Local dev (optional) ---
# Skip Mindbody activation gate so members can reach home/onboarding without activation.
# Must be false in production EAS builds.
EXPO_PUBLIC_SKIP_ACTIVATION_GATING=false

# --- Auth deep links (optional, recommended for production OAuth/recovery) ---
# When set, OAuth and password-recovery redirects use https://HOST/auth/callback
# in addition to the nine71mma:// custom scheme. Requires apple-app-site-association
# and assetlinks.json hosted on the domain.
EXPO_PUBLIC_AUTH_CALLBACK_HOST=app.971mma.com

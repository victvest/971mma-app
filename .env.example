# 971 MMA — environment config
# Copy to `.env` and fill in. Anything prefixed EXPO_PUBLIC_ is inlined into the
# client bundle by the Expo bundler.

# --- Supabase (required) ---
# The anon key is the PUBLIC client key (protected by row-level security).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Integration provider switch (optional) ---
# 'supabase' (default) | 'mindbody'
EXPO_PUBLIC_MEMBER_PROVIDER=supabase
EXPO_PUBLIC_CHECKIN_PROVIDER=supabase

# --- Mindbody (optional, only when integrating later) ---
# Never commit real values. See src/config/integrations.ts and INTEGRATIONS.md.
EXPO_PUBLIC_MINDBODY_BASE_URL=https://api.mindbodyonline.com/public/v6
EXPO_PUBLIC_MINDBODY_API_KEY=
EXPO_PUBLIC_MINDBODY_SITE_ID=
